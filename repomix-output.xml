                    <ScheduleList
                      schedules={savedSchedules}
                      onOpen={handleOpenSchedule}
                      onDelete={handleDeleteSchedule}
                      onBulkDelete={handleBulkDelete}
                      onLogout={() => supabase.auth.signOut()}
